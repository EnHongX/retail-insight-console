{
  "name": "retail-insight-console",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.12.4",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev:web": "pnpm --filter @retail-insight/web dev",
    "dev:api": "pnpm --filter @retail-insight/api start:dev",
    "test": "vitest run",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "validate:domain": "node scripts/validate-retail-domain.mjs",
    "db:generate": "pnpm --filter @retail-insight/api prisma:generate",
    "db:validate": "pnpm --filter @retail-insight/api prisma:validate",
    "db:seed": "pnpm --filter @retail-insight/api prisma:seed"
  },
  "devDependencies": {
    "vitest": "^4.1.7"
  }
}
